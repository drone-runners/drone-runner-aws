# ---------------------------------------------------------#
#                   Get certificates                       #
# ---------------------------------------------------------#
FROM --platform=$BUILDPLATFORM us-west1-docker.pkg.dev/gar-setup/docker/alpine:3.21 as cert-image
RUN apk --update add ca-certificates

# ---------------------------------------------------------#
#                   Build Harness VM Runner                #
# ---------------------------------------------------------#
FROM golang:1.24 as builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy go module files first for better caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build arguments for version information
ARG BUILD_VERSION
ARG BUILD_TIME
ARG COMMIT_SHA
ARG BRANCH_NAME
ARG GIT_TAG

# Binary versions - must match go.mod dependencies
ARG LITE_ENGINE_VERSION=1.0.0
ARG PLUGIN_VERSION=1.0.0
ARG AUTO_INJECTION_VERSION=1.0.0
ARG HCLI_VERSION=1.0.0
ARG TMATE_VERSION=1.0.0

# Validate that go.mod versions match Dockerfile ARG versions
# This ensures library dependencies are in sync with binary versions
RUN set -e; \
    echo "=== Validating binary versions against go.mod ==="; \
    \
    # Check lite-engine
    if grep -q 'github.com/harness/lite-engine' go.mod; then \
        GOMOD_VERSION=$(grep 'github.com/harness/lite-engine' go.mod | awk '{print $2}' | sed 's/v//'); \
        echo "lite-engine: go.mod=v${GOMOD_VERSION}, Dockerfile=${LITE_ENGINE_VERSION}"; \
        if [ "${GOMOD_VERSION}" != "${LITE_ENGINE_VERSION}" ]; then \
            echo "ERROR: lite-engine version mismatch! Update both go.mod and Dockerfile."; \
            exit 1; \
        fi; \
    fi; \
    \
    # Check plugin (if exists in go.mod)
    if grep -q 'github.com/harness/plugin' go.mod; then \
        GOMOD_VERSION=$(grep 'github.com/harness/plugin' go.mod | awk '{print $2}' | sed 's/v//'); \
        echo "plugin: go.mod=v${GOMOD_VERSION}, Dockerfile=${PLUGIN_VERSION}"; \
        if [ "${GOMOD_VERSION}" != "${PLUGIN_VERSION}" ]; then \
            echo "ERROR: plugin version mismatch! Update both go.mod and Dockerfile."; \
            exit 1; \
        fi; \
    fi; \
    \
    # Check auto-injection (if exists in go.mod)
    if grep -q 'github.com/harness/auto-injection' go.mod; then \
        GOMOD_VERSION=$(grep 'github.com/harness/auto-injection' go.mod | awk '{print $2}' | sed 's/v//'); \
        echo "auto-injection: go.mod=v${GOMOD_VERSION}, Dockerfile=${AUTO_INJECTION_VERSION}"; \
        if [ "${GOMOD_VERSION}" != "${AUTO_INJECTION_VERSION}" ]; then \
            echo "ERROR: auto-injection version mismatch! Update both go.mod and Dockerfile."; \
            exit 1; \
        fi; \
    fi; \
    \
    # Check hcli (if exists in go.mod)
    if grep -q 'github.com/harness/hcli' go.mod; then \
        GOMOD_VERSION=$(grep 'github.com/harness/hcli' go.mod | awk '{print $2}' | sed 's/v//'); \
        echo "hcli: go.mod=v${GOMOD_VERSION}, Dockerfile=${HCLI_VERSION}"; \
        if [ "${GOMOD_VERSION}" != "${HCLI_VERSION}" ]; then \
            echo "ERROR: hcli version mismatch! Update both go.mod and Dockerfile."; \
            exit 1; \
        fi; \
    fi; \
    \
    # Check tmate (if exists in go.mod)
    if grep -q 'github.com/harness/tmate' go.mod; then \
        GOMOD_VERSION=$(grep 'github.com/harness/tmate' go.mod | awk '{print $2}' | sed 's/v//'); \
        echo "tmate: go.mod=v${GOMOD_VERSION}, Dockerfile=${TMATE_VERSION}"; \
        if [ "${GOMOD_VERSION}" != "${TMATE_VERSION}" ]; then \
            echo "ERROR: tmate version mismatch! Update both go.mod and Dockerfile."; \
            exit 1; \
        fi; \
    fi; \
    \
    echo "✓ All binary versions validated successfully"

# Build the application for target platform
# CGO is required for sqlite3 support
RUN --mount=type=cache,target=/root/.cache/go-build \
    --mount=type=cache,target=/go/pkg \
    set -e; \
    CGO_ENABLED=1 go build \
    -ldflags "-extldflags \"-static\" \
              -X 'github.com/drone-runners/drone-runner-aws/version.Version=${BUILD_VERSION}' \
              -X 'github.com/drone-runners/drone-runner-aws/version.Commit=${COMMIT_SHA}' \
              -X 'github.com/drone-runners/drone-runner-aws/version.BuildTime=${BUILD_TIME}' \
              -X 'github.com/drone-runners/drone-runner-aws/version.Branch=${BRANCH_NAME}'" \
    -o /app/harness-vm-runner

# ---------------------------------------------------------#
#                   Create final image                     #
# ---------------------------------------------------------#
FROM us-west1-docker.pkg.dev/gar-setup/docker/alpine:3.21

RUN apk add -U --no-cache curl ca-certificates

WORKDIR /app
VOLUME /data
ENV XDG_CACHE_HOME=/data
ENV GODEBUG=netdns=go
ENV HARNESS_PLATFORM_OS=linux
ENV HARNESS_PLATFORM_ARCH=amd64

COPY --from=cert-image /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-certificates.crt
COPY --from=builder /app/harness-vm-runner /bin/harness-vm-runner

# Build metadata labels
ARG BUILD_VERSION
ARG BUILD_TIME
ARG COMMIT_SHA
ARG BRANCH_NAME
ARG GIT_TAG

LABEL org.opencontainers.image.title="Harness VM Runner"
LABEL org.opencontainers.image.description="Harness CI VM-based build runner"
LABEL org.opencontainers.image.vendor="Harness Inc."
LABEL org.opencontainers.image.created="${BUILD_TIME}"
LABEL org.opencontainers.image.revision="${COMMIT_SHA}"
LABEL org.opencontainers.image.source="https://github.com/harness/harness-runner"
LABEL org.opencontainers.image.version="${BUILD_VERSION}"
LABEL BUILD_VERSION="${BUILD_VERSION}"
LABEL BUILD_TIME="${BUILD_TIME}"
LABEL BRANCH_NAME="${BRANCH_NAME}"
LABEL COMMIT_SHA="${COMMIT_SHA}"
LABEL GIT_TAG="${GIT_TAG}"
LABEL com.centurylinklabs.watchtower.stop-signal="SIGINT"

EXPOSE 3000

ENTRYPOINT ["/bin/harness-vm-runner"]
