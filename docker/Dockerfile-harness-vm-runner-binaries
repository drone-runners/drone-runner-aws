# ---------------------------------------------------------#
#          Harness VM Runner Binaries Bundle              #
# ---------------------------------------------------------#
# This Dockerfile creates a binary bundle image containing
# all runtime binaries needed by VMs created by harness-vm-runner.
#
# Binary versions are defined as ARG defaults below and must match
# the versions in harness-vm-runner's go.mod file.
#
# This image is pulled by harness-vm-runner at runtime when
# creating VMs and binaries are extracted and injected via cloud-init.

# Binary versions - must match binary-versions.yaml
ARG LITE_ENGINE_VERSION=1.2.0
ARG PLUGIN_VERSION=1.5.0
ARG AUTO_INJECTION_VERSION=1.1.0
ARG HCLI_VERSION=1.3.0
ARG TMATE_VERSION=1.1.0
ARG ENVMAN_VERSION=1.5.0
ARG OTEL_VERSION=0.148.0
# ENABLE_OTEL controls whether otelcol-contrib is bundled in this image.
# - false (default): binary not included; use OtelPreInstalled=true in cloud-init
#   when the customer has otelcol-contrib installed in their AMI/VM image.
# - true: binary is bundled; use OtelPreInstalled=false in cloud-init
#   so cloud-init extracts it from this image onto the VM.
# Note: ENABLE_OTEL=true includes known CVEs in transitive deps
#   (GHSA-p77j-4mvh-x3m3 grpc critical, GHSA-x744-4wpc-v9h2 docker/docker high).
#   Enable only when log forwarding via OTel is required and CVE risk is accepted.
# Usage: docker build --build-arg ENABLE_OTEL=true ...
ARG ENABLE_OTEL=false

# ---------------------------------------------------------#
#           Pull binary component images                   #
# ---------------------------------------------------------#
FROM us-west1-docker.pkg.dev/gar-setup/docker/harness-vm-runner-lite-engine:${LITE_ENGINE_VERSION} as lite-engine-binary
FROM us-west1-docker.pkg.dev/gar-setup/docker/harness-vm-runner-plugin:${PLUGIN_VERSION} as plugin-binary
FROM us-west1-docker.pkg.dev/gar-setup/docker/harness-vm-runner-auto-injection:${AUTO_INJECTION_VERSION} as auto-injection-binary
FROM us-west1-docker.pkg.dev/gar-setup/docker/harness-vm-runner-hcli:${HCLI_VERSION} as hcli-binary
FROM us-west1-docker.pkg.dev/gar-setup/docker/harness-vm-runner-tmate:${TMATE_VERSION} as tmate-binary
FROM us-west1-docker.pkg.dev/gar-setup/docker/harness-vm-runner-envman:${ENVMAN_VERSION} as envman-binary

# ---------------------------------------------------------#
#       Download OpenTelemetry Collector Binary            #
# ---------------------------------------------------------#
# otel-true: downloads otelcol-contrib when ENABLE_OTEL=true
FROM alpine:3.21.2 as otel-true
ARG OTEL_VERSION
ARG TARGETARCH
RUN apk add --no-cache wget tar && \
    mkdir -p /binaries && \
    wget -nv "https://github.com/open-telemetry/opentelemetry-collector-releases/releases/download/v${OTEL_VERSION}/otelcol-contrib_${OTEL_VERSION}_linux_${TARGETARCH}.tar.gz" -O /tmp/otelcol.tar.gz && \
    tar -xzf /tmp/otelcol.tar.gz -C /binaries otelcol-contrib && \
    chmod +x /binaries/otelcol-contrib && \
    rm /tmp/otelcol.tar.gz

# otel-false: empty stage when ENABLE_OTEL=false (default)
FROM alpine:3.21.2 as otel-false
RUN mkdir -p /binaries

# Select stage based on ENABLE_OTEL flag
FROM otel-${ENABLE_OTEL} as otel-downloader

# ---------------------------------------------------------#
#                Create Binaries Bundle Image              #
# ---------------------------------------------------------#
FROM scratch

WORKDIR /binaries

# Copy all binaries from component images
# Each binary image should have the binary at /binaries/<binary-name>
COPY --from=lite-engine-binary /binaries/lite-engine /binaries/lite-engine
COPY --from=plugin-binary /binaries/plugin /binaries/plugin
COPY --from=auto-injection-binary /binaries/auto-injection /binaries/auto-injection
COPY --from=hcli-binary /binaries/hcli /binaries/hcli
COPY --from=tmate-binary /binaries/tmate /binaries/tmate
COPY --from=envman-binary /binaries/envman /binaries/envman
COPY --from=otel-downloader /binaries/ /binaries/

# Copy version manifest for reference
# This allows operators to inspect which versions are bundled
COPY config/binary-versions.yaml /binaries/versions.yaml

# Build metadata labels
ARG BUILD_VERSION
ARG BUILD_TIME
ARG COMMIT_SHA
ARG BRANCH_NAME
ARG LITE_ENGINE_VERSION
ARG PLUGIN_VERSION
ARG AUTO_INJECTION_VERSION
ARG HCLI_VERSION
ARG TMATE_VERSION
ARG ENVMAN_VERSION
ARG OTEL_VERSION

LABEL org.opencontainers.image.title="Harness VM Runner Binaries"
LABEL org.opencontainers.image.description="Binary bundle for Harness VM Runner"
LABEL org.opencontainers.image.vendor="Harness Inc."
LABEL org.opencontainers.image.created="${BUILD_TIME}"
LABEL org.opencontainers.image.revision="${COMMIT_SHA}"
LABEL org.opencontainers.image.source="https://github.com/harness/harness-runner"
LABEL org.opencontainers.image.version="${BUILD_VERSION}"
LABEL BUILD_VERSION="${BUILD_VERSION}"
LABEL BUILD_TIME="${BUILD_TIME}"
LABEL BRANCH_NAME="${BRANCH_NAME}"
LABEL COMMIT_SHA="${COMMIT_SHA}"
LABEL LITE_ENGINE_VERSION="${LITE_ENGINE_VERSION}"
LABEL PLUGIN_VERSION="${PLUGIN_VERSION}"
LABEL AUTO_INJECTION_VERSION="${AUTO_INJECTION_VERSION}"
LABEL HCLI_VERSION="${HCLI_VERSION}"
LABEL TMATE_VERSION="${TMATE_VERSION}"
LABEL ENVMAN_VERSION="${ENVMAN_VERSION}"
LABEL OTEL_VERSION="${OTEL_VERSION}"
